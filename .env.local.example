# Supabase — get these from your Supabase project dashboard
# Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Settings > API > anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Settings > API > service_role key (only needed for the create-admin script)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Supabase Setup Instructions ───
#
# 1. Create a Supabase project at https://supabase.com
# 2. Copy URL + anon key from Settings > API
# 3. Run this SQL in the SQL Editor:
#
#   -- Gallery images
#   create table gallery_images (
#     id uuid default gen_random_uuid() primary key,
#     src text not null,
#     alt text not null default '',
#     caption text not null default '',
#     sort_order int not null default 0,
#     created_at timestamptz default now()
#   );
#   alter table gallery_images enable row level security;
#   create policy "Public read" on gallery_images for select using (true);
#   create policy "Auth insert" on gallery_images for insert with check (auth.role() = 'authenticated');
#   create policy "Auth update" on gallery_images for update using (auth.role() = 'authenticated');
#   create policy "Auth delete" on gallery_images for delete using (auth.role() = 'authenticated');
#
#   -- Quiz results
#   create table quiz_results (
#     id uuid default gen_random_uuid() primary key,
#     primary_archetype text not null,
#     secondary_archetype text not null,
#     scores jsonb not null default '{}',
#     created_at timestamptz default now()
#   );
#   alter table quiz_results enable row level security;
#   create policy "Public insert" on quiz_results for insert with check (true);
#   create policy "Auth read" on quiz_results for select using (auth.role() = 'authenticated');
#
#   -- Page views / UTM tracking
#   create table page_views (
#     id uuid default gen_random_uuid() primary key,
#     path text not null,
#     referrer text,
#     utm_source text,
#     utm_medium text,
#     utm_campaign text,
#     utm_content text,
#     utm_term text,
#     created_at timestamptz default now()
#   );
#   alter table page_views enable row level security;
#   create policy "Public insert" on page_views for insert with check (true);
#   create policy "Auth read" on page_views for select using (auth.role() = 'authenticated');
#
# 4. Create a Storage bucket:
#    - Go to Storage > New bucket
#    - Name: "mascot-gallery"
#    - Public: ON
#    - Add policy: allow authenticated users to upload/delete
#
# 5. Create your admin user:
#    - Run: npm run create-admin
#    - Enter your email + password when prompted
#    - (Requires SUPABASE_SERVICE_ROLE_KEY to be set above)
